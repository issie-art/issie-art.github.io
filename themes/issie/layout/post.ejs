<%
  const headingMatches = page.content.match(/<h[2-6]\s/g);
  const headingCount = headingMatches ? headingMatches.length : 0;
  const showToc = headingCount >= 2;
%>

<div class="post-layout<%= showToc ? ' has-toc' : '' %>">

<article class="post">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "<%= page.title %>",
  "datePublished": "<%= date(page.date, 'YYYY-MM-DDTHH:mm:ssZ') %>",
  "author": { "@type": "Person", "name": "<%= config.author %>", "email": "xxin778@163.com" },
  "description": "<%= page.description || config.description %>",
  "url": "<%= page.permalink %>",
  "inLanguage": "zh-CN"
}
</script>

    <header class="post-header">
        <h1 class="post-title"><%= page.title %></h1>
        <div class="post-meta">
            <time datetime="<%= date(page.date, 'YYYY-MM-DDTHH:mm:ssZ') %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
        </div>
    </header>

    <div class="post-content">
        <%- page.content %>
    </div>

    <footer class="post-footer">
        <div class="post-navigation">
            <% if (page.prev){ %>
            <a class="prev-post" href="<%- url_for(page.prev.path) %>">← <%= page.prev.title %></a>
            <% } %>
            <% if (page.next){ %>
            <a class="next-post" href="<%- url_for(page.next.path) %>"><%= page.next.title %> →</a>
            <% } %>
        </div>
        <div class="back-home">
            <a href="/">← 返回首页</a>
        </div>
    </footer>
</article>

<% if (showToc) { %>
<aside class="toc-sidebar" id="toc-sidebar">
    <div class="toc-wrapper">
        <h4 class="toc-title">目录</h4>
        <%- toc(page.content, { class: 'toc', list_number: false, min_depth: 2, max_depth: 4 }) %>
    </div>
</aside>
<button class="toc-toggle" id="toc-toggle" aria-label="目录">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3 4h14M3 10h14M3 16h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
</button>
<% } %>

</div>
