<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= page.description || config.description %>">
    <meta name="author" content="<%= config.author %>">
    <meta property="og:title" content="<%= page.title ? page.title + ' | ' + config.title : config.title %>">
    <meta property="og:description" content="<%= page.description || config.description %>">
    <meta property="og:url" content="<%= page.permalink || config.url %>">
    <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
    <link rel="canonical" href="<%= page.permalink || config.url %>">
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <title><%= page.title ? page.title + ' | ' + config.title : config.title %></title>
</head>
<body>
<%
  const headingMatches = is_post() && page.content ? page.content.match(/<h[2-6]\s/g) : null;
  const headingCount = headingMatches ? headingMatches.length : 0;
  const showToc = headingCount >= 2;
%>
<div class="site-wrapper<%= showToc ? ' has-toc' : '' %>">
<% if (!is_home()) { %>
<nav class="site-nav">
    <a href="/">← 首页</a>
</nav>
<% } %>
<main class="site-content<%= is_post() ? ' site-content--post' : '' %>">
<%- body %>
</main>
<footer>
    <div>© <%= date(Date.now(), 'YYYY') %> Issie</div>
</footer>
</div>
<% if (is_post()) { %>
<script src="/js/toc.js" defer></script>
<% } %>
</body>
</html>
